# Normalize line endings to LF on commit (cross-platform safety)
* text=auto eol=lf

# Explicitly declare text files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.mdx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.env*  text eol=lf
*.sh    text eol=lf

# Binary files — do not diff or merge
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.gz    binary

# pnpm lockfile — treat as text, avoid spurious diffs
pnpm-lock.yaml text eol=lf merge=union

# Diff drivers for readability
*.sql   diff=sql
